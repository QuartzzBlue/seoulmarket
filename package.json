{
  "name": "seoulmarket",
  "version": "1.0.0",
  "description": "한국 주식 데이터 수집 및 리포팅 서비스 - Azure Functions",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "prestart": "npm run build",
    "start": "func start",
    "clean": "rimraf dist",
    "crawl": "node dist/scripts/crawl.js"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@azure/storage-blob": "^12.26.0",
    "@azure/storage-queue": "^12.21.0",
    "cheerio": "^1.2.0",
    "openai": "^6.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "azure-functions-core-tools": "^4.0.6610",
    "playwright": "^1.51.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
